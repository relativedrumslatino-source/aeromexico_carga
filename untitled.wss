&lt;button class=&quot;btn-capture&quot; id=&quot;download-btn&quot;&gt;?? Generar Imagen para Enviar&lt;/button&gt;

&lt;script&gt;
    // Auto-llenado de la hora actual al presionar (tanto tablas de tiempo como bloques CD y CT)
    document.querySelectorAll('input[type=&quot;time&quot;], .auto-time').forEach(input =&gt; {
        input.addEventListener('click', function () {
            const ahora = new Date();
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            this.value = `${horas}:${minutos}`;
        });
    });

    // Captura y exportacion a imagen PNG
    document.getElementById('download-btn').addEventListener('click', function () {
        const formElement = document.getElementById('manifiesto-form');
        const button = this;

        button.textContent = &quot;? Generando...&quot;;
        button.disabled = true;

        html2canvas(formElement, {
            scale: 2,
            useCORS: true,
            onclone: (clonedDoc) =&gt; {
                // Sincronizar campos de texto, tiempos y areas de texto
                const inputs = formElement.querySelectorAll('input[type=&quot;text&quot;], input[type=&quot;time&quot;], textarea');
                const clonedInputs = clonedDoc.querySelectorAll('input[type=&quot;text&quot;], input[type=&quot;time&quot;], textarea');
                inputs.forEach((input, index) =&gt; {
                    if(clonedInputs[index]) {
                        clonedInputs[index].value = input.value;
                    }
                });
            }
        }).then(canvas =&gt; {
            const imgData = canvas.toDataURL('image/png');
            const link = document.createElement('a');

            const dateStr = new Date().toISOString().slice(0, 10);
            link.download = `Control_Carga_Cancelado_${dateStr}.png`;

            link.href = imgData;
            link.click();

            button.textContent = &quot;?? Generar Imagen para Enviar&quot;;
            button.disabled = false;
        }).catch(err =&gt; {
            console.error(&quot;Error: &quot;, err);
            button.textContent = &quot;?? Generar Imagen para Enviar&quot;;
            button.disabled = false;
        });
    });
&lt;/script&gt;

