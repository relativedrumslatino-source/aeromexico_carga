        { name: &quot;CERVANTES ORONA JESUS MANUEL&quot;, id: &quot;30085927&quot; },
        { name: &quot;AGUILAR CALVILLO JORGE&quot;, id: &quot;30027168&quot; },
        { name: &quot;MARTINEZ MONTOYA JUAN EDUARDO&quot;, id: &quot;30027189&quot; },
        { name: &quot;MORA GALVAN RITO ANTONIO&quot;, id: &quot;30090376&quot; },
        { name: &quot;HERNANDEZ RODRIGUEZ JUAN ALBERTO&quot;, id: &quot;30092220&quot; },
        { name: &quot;AGUILAR DE LA TORRE JORGE&quot;, id: &quot;30037655&quot; },
        { name: &quot;NINO MARTINEZ JUAN MANUEL&quot;, id: &quot;30027166&quot; },
        { name: &quot;MORA GALVAN RAFAEL GABRIEL&quot;, id: &quot;30096220&quot; },
        { name: &quot;VELAZQUEZ DIEGO&quot;, id: &quot;30005228&quot; },
        { name: &quot;VELAZQUEZ GONZALEZ JUVENAL&quot;, id: &quot;30027180&quot; },
        { name: &quot;SUAREZ CARDENAS GABRIELA JAQUELINE&quot;, id: &quot;30096880&quot; },
        { name: &quot;LUNA AGUINAGA ALAN ALEJANDRO&quot;, id: &quot;30096883&quot; },
        { name: &quot;ORDAZ SERNA JESUS IVAN&quot;, id: &quot;30096882&quot; },
        { name: &quot;SERNA RAMIREZ SOSA ISAIAS&quot;, id: &quot;30097537&quot; },
        { name: &quot;MIRELES SALAS CHRISTOPHER DANIEL&quot;, id: &quot;30097538&quot; }
    ];

    // ORDENAR ALFABETICAMENTE EL ARRAY DE EMPLEADOS POR EL CAMPO 'name'
    empleadosData.sort((a, b) =&gt; a.name.localeCompare(b.name, 'es', { sensitivity: 'base' }));

    // Poblamos dinamicamente todos los selectores de la clase 'tg-select' ya ordenados
    document.querySelectorAll('.tg-select').forEach(selectElement =&gt; {
        let defaultOption = document.createElement('option');
        defaultOption.value = &quot;&quot;;
        defaultOption.textContent = &quot;-- SELECCIONE --&quot;;
        selectElement.appendChild(defaultOption);

        empleadosData.forEach(emp =&gt; {
            let option = document.createElement('option');
            option.value = emp.id;
            option.textContent = emp.name;
            selectElement.appendChild(option);
        });

        selectElement.addEventListener('change', function() {
            const parentRow = this.closest('tr');
            const empInput = parentRow.querySelector('.emp-input');
            if (empInput) {
                empInput.value = this.value;
            }
        });
    });

    // Captura y exportacion del formulario a imagen png
    document.getElementById('download-btn').addEventListener('click', function () {
        const formElement = document.getElementById('manifiesto-form');

        html2canvas(formElement, {
            scale: 2,
            useCORS: true,
            onclone: (clonedDoc) =&gt; {
                const inputs = formElement.querySelectorAll('input[type=&quot;text&quot;], textarea');
                const clonedInputs = clonedDoc.querySelectorAll('input[type=&quot;text&quot;], textarea');
                inputs.forEach((input, index) =&gt; {
                    if(clonedInputs[index]) {
                        clonedInputs[index].value = input.value;
                    }
                });

                const selects = formElement.querySelectorAll('select');
                const clonedSelects = clonedDoc.querySelectorAll('select');
                selects.forEach((select, index) =&gt; {
                    if(clonedSelects[index]) {
                        clonedSelects[index].value = select.value;
                    }
                });
            }
        }).then(canvas =&gt; {
            const link = document.createElement('a');
            link.download = 'Control_Vuelos_Atendidos.png';
            link.href = canvas.toDataURL('image/png');
            link.click();
        });
    });
&lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt;

