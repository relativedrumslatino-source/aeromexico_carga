<site version="3.0"><css/><components/><page id="p18501828" pageindex="0" name="index" pp="1" cp="1"><body generator="0" bgsoundloop="-1" align="1" charset="0" charsetcode="" effectstyle0="0" effectduration0="0" effectstyle1="0" effectduration1="0" effectstyle2="0" effectduration2="0" effectstyle3="0" effectduration3="0" imagetoolbar="0" enableprotect="0" title="FORMATO VUELOS ATENDIDOS" author="RAUL CASTILLO" bgoutput="" bgsoutput="" bgp="1" bsp="1"><Component type="12" id="html1" zorder="0" filename="html21433906" script="
&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;es&quot;&gt;
&lt;head&gt;
    &lt;meta charset=&quot;UTF-8&quot;&gt;
    &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot;&gt;
    &lt;title&gt;Control de Vuelos Atendidos&lt;/title&gt;
    &lt;script src=&quot;https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js&quot;&gt;&lt;/script&gt;
    &lt;style&gt;
        * {
            box-sizing: border-box;
            font-family: 'Courier New', Courier, monospace, Arial;
            font-size: 9px; /* Todo el texto base reducido a tamano 9 */
        }
        body {
            background-color: #f0f2f5;
            margin: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        /* Contenedor principal que se convertira en imagen */
        .form-container {
            background-color: #fff;
            width: 800px;
            border: 3px solid #002060;
            padding: 15px;
            position: relative;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #000;
            padding-bottom: 3px;
            margin-bottom: 8px;
        }
        .logo {
            font-weight: bold;
            color: #002060;
            font-size: 13px;
        }
        .title {
            font-size: 12px;
            font-weight: bold;
            text-align: center;
            flex-grow: 1;
            font-family: Arial, sans-serif;
        }
        .row {
            display: flex;
            gap: 10px;
            margin-bottom: 6px;
            align-items: center;
        }
        .field {
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .field label {
            font-weight: bold;
            white-space: nowrap;
            font-size: 9px;
        }
        input[type=&quot;text&quot;], select {
            border: none;
            border-bottom: 1px dashed #666;
            padding: 1px;
            font-family: 'Courier New', Courier, monospace;
            font-weight: bold;
            font-size: 10px;
            text-transform: uppercase;
            background: transparent;
        }
        select {
            cursor: pointer;
            outline: none;
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
        }
        input:focus, select:focus {
            outline: none;
            border-bottom: 1px solid #002060;
        }
        .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
        .grid-4 { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; }

        .section-title {
            background-color: #fff;
            text-align: center;
            font-weight: bold;
            border: 2px solid #000;
            padding: 3px;
            margin-top: 10px;
            margin-bottom: 0;
            text-transform: uppercase;
            font-family: Arial, sans-serif;
            font-size: 9px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 4px;
        }
        table, th, td {
            border: 1px solid #000;
        }
        th {
            font-family: Arial, sans-serif;
            background-color: #f2f2f2;
            font-size: 9px;
        }
        th, td {
            padding: 2px 4px;
            text-align: left;
            height: 20px;
            font-size: 9px;
        }
        .checkbox-box {
            display: inline-flex;
            align-items: center;
            gap: 2px;
            border: 1px solid #000;
            padding: 1px 3px;
            background: #fff;
            font-weight: bold;
            font-size: 8px;
            cursor: pointer;
        }
        .checkbox-box input {
            margin: 0;
            width: 10px;
            height: 10px;
        }
        .incidencias-container {
            border: 1px solid #000;
            padding: 6px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 5px;
            margin-bottom: 8px;
        }
        .incidencia-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 9px;
        }
        .incidencia-item span {
            font-size: 9px;
        }
        .observaciones-container {
            border: 2px solid #000;
            padding: 8px;
            display: flex;
            gap: 15px;
            margin-top: 8px;
        }
        .obs-column {
            display: flex;
            flex-direction: column;
            gap: 4px;
            width: 15%;
        }
        .obs-column span {
            font-size: 9px;
        }
        .obs-line {
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .obs-line span { width: 12px; font-weight: bold; font-size: 9px; }
        .obs-line input { border: none; border-bottom: 1px solid #000; width: 100%; text-align: center; font-size: 10px; }
        .obs-text {
            width: 70%;
            display: flex;
            flex-direction: column;
        }
        .obs-text span {
            font-size: 9px;
        }
        .obs-text textarea {
            width: 100%;
            flex-grow: 1;
            min-height: 70px;
            border: 1px solid #000;
            resize: none;
            font-family: 'Courier New', Courier, monospace;
            padding: 4px;
            font-weight: bold;
            font-size: 10px;
        }
        .footer-signatures {
            margin-top: 15px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
        }
        .sig-field {
            display: flex;
            margin-bottom: 6px;
            align-items: flex-end;
        }
        .sig-field label { font-weight: bold; white-space: nowrap; font-size: 9px; }
        .sig-field input { border: none; border-bottom: 1px solid #000; width: 100%; font-size: 10px; }
        .doc-code {
            position: absolute;
            bottom: 4px;
            right: 8px;
            font-size: 8px;
            font-weight: bold;
            font-family: Arial, sans-serif;
        }

        /* Boton de Generar Imagen fuera del formulario */
        .btn-capture {
            margin-top: 20px;
            padding: 10px 20px;
            background-color: #002060;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 13px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: background 0.2s;
            font-family: Arial, sans-serif;
        }
        .btn-capture:hover {
            background-color: #001133;
        }
        /* Estilo especifico para centrar el dropdown de incidencia */
        .inc-select {
            width: 100%;
            text-align: center;
        }
    &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;

&lt;div class=&quot;form-container&quot; id=&quot;manifiesto-form&quot;&gt;
    &lt;div class=&quot;header&quot;&gt;
        &lt;div class=&quot;logo&quot;&gt;? AEROMEXICO&lt;/div&gt;
        &lt;div class=&quot;title&quot;&gt;&quot;CONTROL DE VUELOS ATENDIDOS&quot;&lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;row&quot; style=&quot;display: grid; grid-template-columns: 2fr 1fr;&quot;&gt;
        &lt;div class=&quot;field&quot;&gt;
            &lt;label&gt;MATRICULA:&lt;/label&gt;
            &lt;input type=&quot;text&quot; style=&quot;width: 150px;&quot;&gt;
        &lt;/div&gt;
        &lt;div class=&quot;field&quot;&gt;
            &lt;label&gt;FECHA:&lt;/label&gt;
            &lt;input type=&quot;text&quot; style=&quot;width: 30px; text-align: center;&quot; placeholder=&quot;DD&quot;&gt; /
            &lt;input type=&quot;text&quot; style=&quot;width: 30px; text-align: center;&quot; placeholder=&quot;MM&quot;&gt; /
            &lt;input type=&quot;text&quot; style=&quot;width: 40px; text-align: center;&quot; placeholder=&quot;AA&quot;&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;div style=&quot;border: 2px solid #000; padding: 5px; margin-bottom: 8px;&quot;&gt;
        &lt;div class=&quot;grid-3&quot; style=&quot;margin-bottom: 5px;&quot;&gt;
            &lt;div class=&quot;field&quot;&gt;
                &lt;label&gt;VUELO:&lt;/label&gt;
                &lt;input type=&quot;text&quot; style=&quot;width: 60px;&quot;&gt;
                &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; LL&lt;/span&gt;
                &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; SAL&lt;/span&gt;
            &lt;/div&gt;
            &lt;div class=&quot;field&quot;&gt;&lt;label&gt;ORIGEN/DESTINO:&lt;/label&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/div&gt;
            &lt;div class=&quot;field&quot;&gt;&lt;label&gt;POSICION:&lt;/label&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/div&gt;
        &lt;/div&gt;
        &lt;div class=&quot;grid-3&quot; style=&quot;margin-bottom: 5px;&quot;&gt;
            &lt;div class=&quot;field&quot;&gt;&lt;label&gt;HORA DE LLEGADA:&lt;/label&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/div&gt;
            &lt;div class=&quot;field&quot;&gt;
                &lt;label&gt;BRIEFING:&lt;/label&gt;
                &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; SI&lt;/span&gt;
                &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; NO&lt;/span&gt;
            &lt;/div&gt;
            &lt;div class=&quot;field&quot;&gt;&lt;label&gt;HORA DE SALIDA:&lt;/label&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/div&gt;
        &lt;/div&gt;
        &lt;div class=&quot;grid-3&quot;&gt;
            &lt;div class=&quot;field&quot;&gt;&lt;label&gt;CANTIDAD ARPEL:&lt;/label&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/div&gt;
            &lt;div class=&quot;field&quot; style=&quot;grid-column: span 2;&quot;&gt;&lt;label&gt;FOLIOS ARPEL:&lt;/label&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class=&quot;section-title&quot;&gt;Datos del Personal que Atiende el Vuelo de &quot;Llegada&quot;&lt;/div&gt;
    &lt;table&gt;
        &lt;thead&gt;
            &lt;tr&gt;
                &lt;th style=&quot;width: 45%;&quot;&gt;NOMBRE&lt;/th&gt;
                &lt;th style=&quot;width: 15%; text-align: center;&quot;&gt;INCIDENCIA&lt;/th&gt;
                &lt;th style=&quot;width: 20%; text-align: center;&quot;&gt;TIPO&lt;/th&gt;
                &lt;th style=&quot;width: 20%;&quot;&gt;No. EMPLEADO&lt;/th&gt;
            &lt;/tr&gt;
        &lt;/thead&gt;
        &lt;tbody&gt;
            &lt;tr&gt;
                &lt;td&gt;NOMBRE OO: &lt;input type=&quot;text&quot; style=&quot;width: 75%;&quot;&gt;&lt;/td&gt;
                &lt;td&gt;
                    &lt;select class=&quot;inc-select&quot;&gt;
                        &lt;option value=&quot;&quot;&gt;&lt;/option&gt;
                        &lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;
                        &lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;
                        &lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;
                        &lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;
                        &lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;
                        &lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;
                    &lt;/select&gt;
                &lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;

            &lt;tr&gt;
                &lt;td&gt;NOMBRE DEL TG: &lt;select class=&quot;tg-select&quot; style=&quot;width: 65%;&quot;&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; class=&quot;emp-input&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
                &lt;td&gt;NOMBRE DEL TG: &lt;select class=&quot;tg-select&quot; style=&quot;width: 65%;&quot;&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; class=&quot;emp-input&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
                &lt;td&gt;NOMBRE DEL TG: &lt;select class=&quot;tg-select&quot; style=&quot;width: 65%;&quot;&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; class=&quot;emp-input&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
                &lt;td&gt;NOMBRE DEL TG: &lt;select class=&quot;tg-select&quot; style=&quot;width: 65%;&quot;&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; class=&quot;emp-input&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
                &lt;td&gt;NOMBRE DEL TG: &lt;select class=&quot;tg-select&quot; style=&quot;width: 65%;&quot;&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; class=&quot;emp-input&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;
            &lt;tr&gt;
                &lt;td&gt;NOMBRE DEL TG: &lt;select class=&quot;tg-select&quot; style=&quot;width: 65%;&quot;&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; class=&quot;emp-input&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;
        &lt;/tbody&gt;
    &lt;/table&gt;
    &lt;div class=&quot;field&quot; style=&quot;margin-bottom: 8px;&quot;&gt;&lt;label&gt;CLAVE DE LOS GRUPOS ASIGNADOS:&lt;/label&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/div&gt;

    &lt;div class=&quot;section-title&quot;&gt;Datos del Personal que Atiende el Vuelo de &quot;Salida&quot;&lt;/div&gt;
    &lt;table&gt;
        &lt;thead&gt;
            &lt;tr&gt;
                &lt;th style=&quot;width: 45%;&quot;&gt;NOMBRE&lt;/th&gt;
                &lt;th style=&quot;width: 15%; text-align: center;&quot;&gt;INCIDENCIA&lt;/th&gt;
                &lt;th style=&quot;width: 20%; text-align: center;&quot;&gt;TIPO&lt;/th&gt;
                &lt;th style=&quot;width: 20%;&quot;&gt;No. EMPLEADO&lt;/th&gt;
            &lt;/tr&gt;
        &lt;/thead&gt;
        &lt;tbody&gt;
            &lt;tr&gt;
                &lt;td&gt;NOMBRE OO: &lt;input type=&quot;text&quot; style=&quot;width: 75%;&quot;&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;

            &lt;tr&gt;
                &lt;td&gt;NOMBRE DEL TG: &lt;select class=&quot;tg-select&quot; style=&quot;width: 65%;&quot;&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td&gt;&lt;select class=&quot;inc-select&quot;&gt;&lt;option value=&quot;&quot;&gt;&lt;/option&gt;&lt;option value=&quot;1&quot;&gt;1&lt;/option&gt;&lt;option value=&quot;2&quot;&gt;2&lt;/option&gt;&lt;option value=&quot;3&quot;&gt;3&lt;/option&gt;&lt;option value=&quot;4&quot;&gt;4&lt;/option&gt;&lt;option value=&quot;5&quot;&gt;5&lt;/option&gt;&lt;option value=&quot;6&quot;&gt;6&lt;/option&gt;&lt;/select&gt;&lt;/td&gt;
                &lt;td style=&quot;text-align: center;&quot;&gt;&lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CD&lt;/span&gt; &lt;span class=&quot;checkbox-box&quot;&gt;&lt;input type=&quot;checkbox&quot;&gt; CT&lt;/span&gt;&lt;/td&gt;
                &lt;td&gt;&lt;input type=&quot;text&quot; class=&quot;emp-input&quot; style=&quot;width: 100%;&quot;&gt;&lt;/td&gt;
            &lt;/tr&gt;
